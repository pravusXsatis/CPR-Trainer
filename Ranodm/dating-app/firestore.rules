rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn() && request.auth.uid in request.resource.data.users;
      allow update, delete: if false;
    }
  }
}
